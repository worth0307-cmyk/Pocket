# ============ Telegram（必填）============
# 找 @BotFather 创建机器人拿到 token
TELEGRAM_BOT_TOKEN=
# 接收自动提醒的聊天 ID（找 @userinfobot 获取你的数字 ID）
TELEGRAM_CHAT_ID=
# 允许控制机器人的 Chat ID 列表，逗号分隔；留空=默认用 TELEGRAM_CHAT_ID（仅你本人可用）
ALLOWED_CHAT_IDS=

# ============ 数据源 API Key（免费，按需填）============
# EVM 链（ETH/BSC/Base/Arb/Polygon/OP）跟踪需要：https://etherscan.io/myapikey
# 一个 key 通吃所有 EVM 链（Etherscan V2）。不填则这些链不可用。
ETHERSCAN_API_KEY=
# Solana 动作解析需要：https://dashboard.helius.dev （免费档）
# 不填则 Solana 只能查余额、无法自动跟踪买卖。
HELIUS_API_KEY=
# 比特币使用 mempool.space，无需 key。
# USD 估值 / 盈亏估算使用 CoinGecko 公共接口，无需 key。

# ============ 运行参数 ============
# 自动跟踪轮询间隔（秒），最小 20
POLL_INTERVAL=60
# SQLite 数据库文件路径
DB_PATH=wallets.db

# ============ 网页面板 ============
WEB_ENABLED=true
# 默认只监听本机，安全。要外网访问改 0.0.0.0 并务必设置 WEB_TOKEN / 加反向代理
WEB_HOST=127.0.0.1
WEB_PORT=8000
# 网页访问令牌，留空=不校验（仅建议本机访问时留空）
WEB_TOKEN=
